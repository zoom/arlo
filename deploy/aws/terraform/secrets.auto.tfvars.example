# Bootstrap-only option.
#
# This is convenient, but Terraform state will contain these secret values.
# For production, prefer put-secrets.sh so values go directly to SSM
# Parameter Store SecureString and never enter Terraform state.

manage_secret_values = true

secret_values = {
  "zoom-client-id"            = "YOUR_ZOOM_CLIENT_ID"
  "zoom-client-secret"        = "YOUR_ZOOM_CLIENT_SECRET"
  "zoom-webhook-secret-token" = "YOUR_ZOOM_WEBHOOK_SECRET_TOKEN"
  "session-secret"            = "GENERATE_WITH_OPENSSL_RAND_HEX_32"
  "redis-encryption-key"      = "GENERATE_WITH_OPENSSL_RAND_HEX_16_EXACTLY_32_CHARS"
  "internal-webhook-secret"   = "GENERATE_WITH_OPENSSL_RAND_HEX_32"
  "openrouter-api-key"        = "OPTIONAL_OPENROUTER_API_KEY"
}
