# Shared application settings
APP_NAME=arlo
PUBLIC_URL=https://arlo.example.com
DATABASE_URL=mysql://arlo:change-me@db.example.com:3306/meeting_assistant
MYSQL_USER=arlo
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Zoom credentials
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_APP_ID=
RTMS_CLIENT_ID=
ZOOM_HOST=zoom.us

# Required secrets
SESSION_SECRET=
REDIS_ENCRYPTION_KEY=

# Optional AI settings
OPENROUTER_API_KEY=
DEFAULT_MODEL=openai/gpt-oss-120b:free
FALLBACK_MODEL=google/gemma-4-31b-it:free
FALLBACK_MODELS=google/gemma-4-31b-it:free,nvidia/nemotron-3-ultra-550b-a55b:free
AI_ENABLED=false
EXTRACTION_ENABLED=false
PUBLIC_LINKS_ENABLED=false
DISABLE_MEETING_PERSISTENCE=false
LOG_LEVEL=info

# Prebuilt container images
BACKEND_IMAGE=ghcr.io/your-org/arlo-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/arlo-frontend:latest
RTMS_IMAGE=ghcr.io/your-org/arlo-rtms:latest

# AWS
AWS_REGION=us-east-1
AWS_BACKEND_SERVICE=arlo-backend
AWS_FRONTEND_SERVICE=arlo-frontend
AWS_RTMS_SERVICE=arlo-rtms
AWS_APP_RUNNER_ECR_ACCESS_ROLE_ARN=
AWS_APP_RUNNER_CPU="0.25 vCPU"
AWS_APP_RUNNER_MEMORY="0.5 GB"

# Self-hosted
SELFHOST_PROJECT_NAME=arlo
SELFHOST_BIND_BACKEND_PORT=3000
SELFHOST_BIND_FRONTEND_PORT=3001
SELFHOST_BIND_RTMS_PORT=3002
