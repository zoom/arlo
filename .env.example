# =============================================================================
# ZOOM APP CREDENTIALS
# =============================================================================
# Get these from https://marketplace.zoom.us/ → Your App → App Credentials
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here

# Zoom App ID (optional, for selecting meetings for auto-opening)
# Get from the app marketplace: https://marketplace.zoom.us/apps
# The app ID is in the path of the app page URL:
# https://marketplace.zoom.us/develop/applications/{your-app-id}
ZOOM_APP_ID=

# Zoom for Government (ZfG) Support
# For standard Zoom: leave as zoom.us (default)
# For Zoom for Government: set to zoomgov.com
ZOOM_HOST=zoom.us

# =============================================================================
# PUBLIC URL
# =============================================================================
# For local development: Your ngrok HTTPS URL (e.g., https://abc123.ngrok-free.app)
# For production: Your domain (e.g., https://arlo-meeting-assistant.example.com)
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# OAuth Redirect URI (automatically constructed from PUBLIC_URL)
# Must match exactly what's configured in Zoom Marketplace
ZOOM_APP_REDIRECT_URI=${PUBLIC_URL}/api/auth/callback

# =============================================================================
# DATABASE
# =============================================================================
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local development (Docker): mysql://arlo:arlo@mysql:3306/meeting_assistant
# Local development (Manual): mysql://arlo:arlo@localhost:3306/meeting_assistant
MYSQL_USER=arlo
MYSQL_PASSWORD=arlo
MYSQL_ROOT_PASSWORD=change-me-root
DATABASE_URL=mysql://arlo:arlo@mysql:3306/meeting_assistant

# =============================================================================
# SECURITY KEYS
# =============================================================================
# Session secret for Express session management
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_64_character_random_string_here

# Encryption key for storing Zoom tokens (must be exactly 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
REDIS_ENCRYPTION_KEY=your_32_character_encryption_key

# =============================================================================
# REDIS (Optional - for WebSocket scaling)
# =============================================================================
# Leave empty to use in-memory store (fine for development/single instance)
# For production with multiple instances: redis://localhost:6379
REDIS_URL=

# =============================================================================
# AI CONFIGURATION (OpenRouter)
# =============================================================================
# OpenRouter API key (optional; keep only free model IDs configured below)
# Get from: https://openrouter.ai/keys
# Leave empty to use free models with rate limits (10 req/min)
OPENROUTER_API_KEY=

# Default AI model to use
# Free options:
#   - openai/gpt-oss-120b:free
#   - google/gemma-4-31b-it:free
#   - nvidia/nemotron-3-ultra-550b-a55b:free
DEFAULT_MODEL=openai/gpt-oss-120b:free

# Fallback models if default fails
FALLBACK_MODEL=google/gemma-4-31b-it:free
FALLBACK_MODELS=google/gemma-4-31b-it:free,nvidia/nemotron-3-ultra-550b-a55b:free

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable AI features (chat, suggestions, summaries)
AI_ENABLED=true

# Enable background extraction jobs (action items, decisions)
EXTRACTION_ENABLED=false

# Enable public sharing links (future feature)
PUBLIC_LINKS_ENABLED=false

# Disable meeting persistence (demo mode)
# When true, transcripts are NOT saved to the database
# Real-time features still work, but no meeting history is kept
DISABLE_MEETING_PERSISTENCE=false

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Backend server port
PORT=3000

# Node environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Frontend upstream URL (used by the backend proxy in multi-service deployments)
# Local Docker default: http://frontend:3000
# Managed deployments: set to the frontend service's public HTTPS URL
FRONTEND_UPSTREAM_URL=http://frontend:3000

# Number of trusted reverse proxies in front of the backend.
# AWS CloudFront -> ALB deployments use 2. Direct/local deployments use 0.
TRUST_PROXY_HOPS=0

# =============================================================================
# RTMS CONFIGURATION
# =============================================================================
# Zoom Marketplace Event Subscriptions secret token.
# This verifies Zoom webhook notifications; it is not used for RTMS signaling.
ZOOM_WEBHOOK_SECRET_TOKEN=

# Backward-compatible alias for ZOOM_WEBHOOK_SECRET_TOKEN
RTMS_WEBHOOK_SECRET=

# RTMS app client ID used by the optional REST API start method.
# Defaults to ZOOM_CLIENT_ID when the OAuth and RTMS app are the same General App.
RTMS_CLIENT_ID=

# HMAC secret for backend-to-RTMS internal webhook forwarding
INTERNAL_WEBHOOK_SECRET=

# RTMS server port (if running separately)
RTMS_PORT=3002

# RTMS SDK log level (v1.0+, replaces configureLogger())
# Options: error, warn, info, debug, trace
# Set via ZM_RTMS_LOG_LEVEL env var (handled in docker-compose.yml)
# ZM_RTMS_LOG_LEVEL=debug

# =============================================================================
# LOGGING
# =============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=${PUBLIC_URL},http://localhost:3001

# =============================================================================
# FILE STORAGE
# =============================================================================
# Directory for VTT files
VTT_STORAGE_PATH=./storage/vtt

# S3-compatible storage (optional, for production)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
